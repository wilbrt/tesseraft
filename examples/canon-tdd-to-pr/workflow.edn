{:api-version "tesseraft.workflow/v1"
 :kind :workflow
 :metadata {:name "canon-tdd-to-pr"
            :title "Canon TDD to PR"
            :description "Turn a prompt into an approved agile use case, then implement one behavioral scenario at a time with Canon TDD in an isolated worktree before review and PR creation."}
 :inputs {:prompt {:type :string :required true}
          :repo-root {:type :path :required true}
          :base-branch {:type :string :default "main"}
          :branch {:type :string :required false}}
 :defaults {:max-rounds 50
            :state-timeout "45m"
            :approval-timeout "7d"
            :base-branch "main"}
 :policies {:runtime-cannot-edit-workflow true
            :authoring-cannot-edit-runs true
            :require-timeouts true
            :require-max-rounds true
            :require-status-output-for-agent-nodes true
            :forbid-inline-secrets true
            :allowed-agent-tools [:read :bash :edit :write :grep :find :ls]}
 :initial :collect-prompt
 :states
 {:collect-prompt
  {:type :process
   :title "Collect prompt"
   :command ["./scripts/collect_prompt.py"]
   :input-mode :json-stdin
   :output-mode :json-stdout
   :runtime {:timeout "30s"}
   :outputs {:prompt-json {:path "prompt/prompt.json" :required true}
             :prompt-md {:path "prompt/prompt.md" :required true}}
   :next :write-use-case}

  :write-use-case
  {:type :agent
   :title "Write agile use case"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.6-sol"
   :thinking "medium"
   :prompt-template "prompts/write-use-case.md.tmpl"
   :prompt-output "prompts/generated/write-use-case-{{run.round}}.md"
   :session-name "canon-tdd-use-case-{{run.round}}"
   :tools [:read :bash :grep :find :ls :write]
   :runtime {:cwd "{{inputs.repo-root}}" :timeout "45m"}
   :outputs {:status {:path "use-case/status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :use-case {:path "use-case/use-case-{{run.round}}.md" :required true}}
   :transitions [{:when {:status "pass"} :next :approve-use-case}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :write-use-case}]}

  :approve-use-case
  {:type :approval
   :title "Approve use case"
   :message "Review the agile use case. Approve its behavioral scope or request a revision before test-list creation."
   :timeout "7d"
   :artifact {:path "use-case/use-case-{{run.round}}.md" :type "text/markdown"}
   :presentation {:question "Does this use case accurately describe the requested actor goal, observable behavior, alternate flows, and scope?"
                  :artifacts [{:path "use-case/use-case-{{run.round}}.md" :type "text/markdown" :label "Use case"}]
                  :decisions [{:decision "approve" :label "Approve use case" :next "build-test-list"}
                              {:decision "revise" :label "Request revision" :next "write-use-case"}]
                  :routing {:kind :self}}
   :transitions [{:when {:decision "approve"} :next :build-test-list}
                 {:when {:decision "revise"} :effects [:inc-round] :next :write-use-case}]}

  :build-test-list
  {:type :agent
   :title "Build behavioral test list"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.6-sol"
   :thinking "medium"
   :prompt-template "prompts/build-test-list.md.tmpl"
   :prompt-output "prompts/generated/build-test-list-{{run.round}}.md"
   :session-name "canon-tdd-test-list-{{run.round}}"
   :tools [:read :bash :grep :find :ls :write]
   :runtime {:cwd "{{inputs.repo-root}}" :timeout "45m"}
   :outputs {:status {:path "test-list/build-status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :test-list-json {:path "test-list/scenarios-initial.json" :required true}
             :test-list-md {:path "test-list/scenarios-initial.md" :required true}}
   :transitions [{:when {:status "pass"} :next :choose-branch}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :build-test-list}]}

  :choose-branch
  {:type :agent
   :title "Choose branch and record repository constraints"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.6-sol"
   :thinking "medium"
   :prompt-template "prompts/choose-branch.md.tmpl"
   :prompt-output "prompts/generated/choose-branch-{{run.round}}.md"
   :session-name "canon-tdd-branch-{{run.round}}"
   :tools [:read :bash :grep :find :ls :write]
   :runtime {:cwd "{{inputs.repo-root}}" :timeout "30m"}
   :outputs {:status {:path "design/status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :constraints {:path "design/repository-constraints.md" :required true}
             :branch-name {:path "design/branch-name.txt" :required true}}
   :transitions [{:when {:status "pass"} :next :ensure-worktree}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :choose-branch}]}

  :ensure-worktree
  {:type :deterministic
   :title "Create isolated worktree"
   :handler :git/ensure-worktree
   :runtime {:timeout "5m"}
   :inputs {:branch-file "design/branch-name.txt"}
   :outputs {:worktree-path {:path "worktree/path.txt" :required true}}
   :next :select-scenario}

  :select-scenario
  {:type :agent
   :title "Select exactly one pending scenario"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.6-sol"
   :thinking "medium"
   :prompt-template "prompts/select-scenario.md.tmpl"
   :prompt-output "prompts/generated/select-scenario-{{run.round}}.md"
   :session-name "canon-tdd-select-{{run.round}}"
   :tools [:read :bash :grep :find :ls :write]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "30m"}
   :outputs {:status {:path "tdd/select-status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :scenario {:path "tdd/current-scenario-{{run.round}}.json" :required true}
             :selection-notes {:path "tdd/selection-{{run.round}}.md" :required true}}
   :transitions [{:when {:status "actions_needed"} :next :write-one-test}
                 {:when {:status "no_actions"} :next :regression-testing}
                 {:when {:status "pass"} :next :write-one-test}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :select-scenario}]}

  :write-one-test
  {:type :agent
   :title "Write one concrete failing test"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.5"
   :thinking "medium"
   :prompt-template "prompts/write-one-test.md.tmpl"
   :prompt-output "prompts/generated/write-one-test-{{run.round}}.md"
   :session-name "canon-tdd-write-test-{{run.round}}"
   :tools [:read :bash :edit :write :grep :find :ls]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "60m"}
   :outputs {:status {:path "tdd/write-test-status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :report {:path "tdd/test-{{run.round}}.md" :required true}
             :test-command {:path "tdd/test-command-{{run.round}}.txt" :required true}
             :issues {:path "tdd/write-test-issues-{{run.round}}.json" :schema "../../schemas/issues.schema.json" :required false}}
   :transitions [{:when {:status "pass"} :next :verify-red}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :write-one-test}]}

  :verify-red
  {:type :agent
   :title "Verify meaningful red"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.4"
   :thinking "medium"
   :prompt-template "prompts/verify-red.md.tmpl"
   :prompt-output "prompts/generated/verify-red-{{run.round}}.md"
   :session-name "canon-tdd-red-{{run.round}}"
   :tools [:read :bash :grep :find :ls :write]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "45m"}
   :outputs {:status {:path "tdd/red-status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :report {:path "tdd/red-report-{{run.round}}.md" :required true}
             :issues {:path "tdd/red-issues-{{run.round}}.json" :schema "../../schemas/issues.schema.json" :required false}}
   :transitions [{:when {:status "pass"} :next :make-green}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :write-one-test}]}

  :make-green
  {:type :agent
   :title "Make current and previous tests pass"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.5"
   :thinking "medium"
   :prompt-template "prompts/make-green.md.tmpl"
   :prompt-output "prompts/generated/make-green-{{run.round}}.md"
   :session-name "canon-tdd-green-{{run.round}}"
   :tools [:read :bash :edit :write :grep :find :ls]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "90m"}
   :outputs {:status {:path "tdd/green-status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :summary {:path "tdd/green-summary-{{run.round}}.md" :required true}
             :discoveries {:path "tdd/discovered-scenarios-{{run.round}}.json" :required true}
             :issues {:path "tdd/green-issues-{{run.round}}.json" :schema "../../schemas/issues.schema.json" :required false}}
   :transitions [{:when {:status "pass"} :next :verify-green}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :make-green}]}

  :verify-green
  {:type :agent
   :title "Verify green"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.4"
   :thinking "medium"
   :prompt-template "prompts/verify-green.md.tmpl"
   :prompt-output "prompts/generated/verify-green-{{run.round}}.md"
   :session-name "canon-tdd-verify-green-{{run.round}}"
   :tools [:read :bash :grep :find :ls :write]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "45m"}
   :outputs {:status {:path "tdd/green-verification-status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :report {:path "tdd/green-verification-{{run.round}}.md" :required true}
             :issues {:path "tdd/green-verification-issues-{{run.round}}.json" :schema "../../schemas/issues.schema.json" :required false}}
   :transitions [{:when {:status "pass"} :next :optional-refactor}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :make-green}]}

  :optional-refactor
  {:type :agent
   :title "Optionally refactor"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.6-sol"
   :thinking "medium"
   :prompt-template "prompts/optional-refactor.md.tmpl"
   :prompt-output "prompts/generated/optional-refactor-{{run.round}}.md"
   :session-name "canon-tdd-refactor-{{run.round}}"
   :tools [:read :bash :edit :write :grep :find :ls]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "60m"}
   :outputs {:status {:path "tdd/refactor-status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :summary {:path "tdd/refactor-summary-{{run.round}}.md" :required true}
             :issues {:path "tdd/refactor-issues-{{run.round}}.json" :schema "../../schemas/issues.schema.json" :required false}}
   :transitions [{:when {:status "pass"} :next :verify-refactor}
                 {:when {:status "no_actions"} :next :update-test-list}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :optional-refactor}]}

  :verify-refactor
  {:type :agent
   :title "Verify refactoring preserved behavior"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.4"
   :thinking "medium"
   :prompt-template "prompts/verify-refactor.md.tmpl"
   :prompt-output "prompts/generated/verify-refactor-{{run.round}}.md"
   :session-name "canon-tdd-verify-refactor-{{run.round}}"
   :tools [:read :bash :grep :find :ls :write]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "45m"}
   :outputs {:status {:path "tdd/refactor-verification-status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :report {:path "tdd/refactor-verification-{{run.round}}.md" :required true}
             :issues {:path "tdd/refactor-verification-issues-{{run.round}}.json" :schema "../../schemas/issues.schema.json" :required false}}
   :transitions [{:when {:status "pass"} :next :update-test-list}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :optional-refactor}]}

  :update-test-list
  {:type :agent
   :title "Complete scenario and update test list"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.6-sol"
   :thinking "medium"
   :prompt-template "prompts/update-test-list.md.tmpl"
   :prompt-output "prompts/generated/update-test-list-{{run.round}}.md"
   :session-name "canon-tdd-update-list-{{run.round}}"
   :tools [:read :bash :grep :find :ls :write]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "30m"}
   :outputs {:status {:path "test-list/update-status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :test-list-json {:path "test-list/scenarios-{{run.round}}.json" :required true}
             :test-list-md {:path "test-list/scenarios-{{run.round}}.md" :required true}}
   :transitions [{:when {:status "actions_needed"} :effects [:inc-round] :next :select-scenario}
                 {:when {:status "no_actions"} :next :regression-testing}
                 {:when {:status "pass"} :effects [:inc-round] :next :select-scenario}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :update-test-list}]}

  :regression-testing
  {:type :agent
   :title "Independent regression testing"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.4"
   :thinking "medium"
   :prompt-template "prompts/regression-testing.md.tmpl"
   :prompt-output "prompts/generated/regression-testing-{{run.round}}.md"
   :session-name "canon-tdd-regression-{{run.round}}"
   :tools [:read :bash :grep :find :ls :write]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "60m"}
   :outputs {:status {:path "manual-testing/status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :report {:path "manual-testing/report-{{run.round}}.md" :required true}
             :issues {:path "manual-testing/issues-{{run.round}}.json" :schema "../../schemas/issues.schema.json" :required false}}
   :transitions [{:when {:status "pass"} :next :review}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :repair}]}

  :review
  {:type :agent
   :title "Code and Canon TDD review"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.6-sol"
   :thinking "medium"
   :prompt-template "prompts/review.md.tmpl"
   :prompt-output "prompts/generated/review-{{run.round}}.md"
   :session-name "canon-tdd-review-{{run.round}}"
   :tools [:read :bash :grep :find :ls :write]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "45m"}
   :outputs {:status {:path "review/status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :report {:path "review/report-{{run.round}}.md" :required true}
             :issues {:path "review/issues-{{run.round}}.json" :schema "../../schemas/issues.schema.json" :required false}}
   :transitions [{:when {:status "pass"} :effects [:clear-issues] :next :pr-draft}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :repair}]}

  :repair
  {:type :agent
   :title "Repair regression or review findings"
   :executor :pi-cli
   :provider "openai-codex"
   :model "gpt-5.5"
   :thinking "medium"
   :prompt-template "prompts/repair.md.tmpl"
   :prompt-output "prompts/generated/repair-{{run.round}}.md"
   :session-name "canon-tdd-repair-{{run.round}}"
   :tools [:read :bash :edit :write :grep :find :ls]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "90m"}
   :outputs {:status {:path "repair/status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :summary {:path "repair/summary-{{run.round}}.md" :required true}
             :issues {:path "repair/issues-{{run.round}}.json" :schema "../../schemas/issues.schema.json" :required false}}
   :transitions [{:when {:status "pass"} :next :regression-testing}
                 {:when {:status "fail"} :effects [:merge-issues :inc-round] :next :repair}]}

  :pr-draft
  {:type :agent
   :title "Draft PR metadata"
   :executor :pi-cli
   :prompt-template "prompts/pr-draft.md.tmpl"
   :prompt-output "prompts/generated/pr-draft-{{run.round}}.md"
   :session-name "canon-tdd-pr-draft-{{run.round}}"
   :tools [:read :bash :grep :find :ls :write]
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "20m"}
   :outputs {:status {:path "pr/draft-status-{{run.round}}.json" :schema "../../schemas/status.schema.json" :required true}
             :title {:path "pr/pr-title.txt" :required true}
             :body {:path "pr/pr-body.md" :required true}}
   :transitions [{:when {:status "pass"} :next :create-pr}
                 {:when {:status "fail"} :effects [:inc-round] :next :pr-draft}]}

  :create-pr
  {:type :deterministic
   :title "Create pull request"
   :handler :github/create-pr
   :runtime {:cwd "{{run.worktree-dir}}" :timeout "5m" :requires-secrets [:github-token]}
   :inputs {:title-file "pr/pr-title.txt"
            :body-file "pr/pr-body.md"
            :branch-file "design/branch-name.txt"
            :repo-dir-file "worktree/path.txt"}
   :outputs {:pr-json {:path "pr/pr.json" :required true}}
   :next :done}

  :done
  {:type :terminal
   :title "Done"
   :status :success}}}
