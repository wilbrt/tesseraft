{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Canon TDD Focused Check",
  "type": "object",
  "required": ["version", "scenario_id", "id", "command", "timeout_seconds", "red"],
  "properties": {
    "version": {"const": 1},
    "scenario_id": {"type": "string", "minLength": 1},
    "id": {"type": "string", "minLength": 1},
    "command": {
      "oneOf": [
        {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        {"type": "string", "minLength": 1}
      ]
    },
    "shell": {"type": "boolean", "default": false},
    "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 7200},
    "red": {
      "type": "object",
      "required": ["expected_exit", "output_contains"],
      "properties": {
        "expected_exit": {"const": "nonzero"},
        "output_contains": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
