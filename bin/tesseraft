#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="0.1.0"
cmd="${1:-}"
case "$cmd" in
  --version|version)
    echo "tesseraft $VERSION"
    ;;
  lint)
    shift
    exec "$SCRIPT_DIR/agent-workflow-lint" "$@"
    ;;
  run)
    shift
    exec "$SCRIPT_DIR/agent-workflow-run" "$@"
    ;;
  node)
    shift
    ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
    exec bb --config "$ROOT_DIR/bb.edn" node "$@"
    ;;
  control-plane)
    shift
    ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
    exec bb --config "$ROOT_DIR/bb.edn" control-plane "$@"
    ;;
  ""|-h|--help|help)
    echo "Usage: tesseraft <command> [args]"
    echo
    echo "Commands:"
    echo "  lint      Validate workflow definitions"
    echo "  run       Run or inspect workflow executions"
    echo "  node      Validate and manage self-contained node packages"
    echo "  control-plane  Inspect workflows and runs via the read-only local API"
    echo "  version   Print version information"
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo "Usage: tesseraft <lint|run|node|control-plane|version> [args]" >&2
    exit 2
    ;;
esac
