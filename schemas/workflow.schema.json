{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tesseraft Workflow Definition (normalized JSON shape)",
  "type": "object",
  "required": [
    "api-version",
    "kind",
    "metadata",
    "initial",
    "states"
  ],
  "$defs": {
    "resourceDeclaration": {
      "type": "object",
      "properties": {
        "requires": { "$ref": "#/$defs/resourceList" },
        "consumes": { "$ref": "#/$defs/resourceList" },
        "produces": { "$ref": "#/$defs/resourceList" }
      },
      "additionalProperties": true
    },
    "resourceList": {
      "type": "array",
      "items": { "$ref": "#/$defs/resource" }
    },
    "resource": {
      "type": "object",
      "required": ["kind", "name"],
      "properties": {
        "kind": { "type": "string" },
        "name": { "type": "string" },
        "path": { "type": "string" },
        "mode": { "type": "string" },
        "description": { "type": "string" },
        "schema": { "type": "string" },
        "source": { "type": "string" },
        "tool": { "type": "string" },
        "secret": { "type": ["string", "boolean"] },
        "handler": { "type": "string" },
        "executor": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "api-version": {
      "const": "tesseraft.workflow/v1"
    },
    "kind": {
      "const": "workflow"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name"
      ]
    },
    "inputs": {
      "type": "object"
    },
    "defaults": {
      "type": "object"
    },
    "policies": {
      "type": "object"
    },
    "initial": {
      "type": "string"
    },
    "states": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "resources": { "$ref": "#/$defs/resourceDeclaration" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
