{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tesseraft Self-contained Fragment Package",
  "description": "A reusable multi-node subgraph with a declared boundary contract (tesseraft.fragment/v1). Inclusion lints the boundary; internal proof is done once by lint-fragment-package.",
  "type": "object",
  "required": [
    "api-version",
    "kind",
    "metadata",
    "interface",
    "fragment"
  ],
  "$defs": {
    "resourceDeclaration": {
      "type": "object",
      "properties": {
        "requires": { "$ref": "#/$defs/resourceList" },
        "consumes": { "$ref": "#/$defs/resourceList" },
        "produces": { "$ref": "#/$defs/resourceList" }
      },
      "additionalProperties": true
    },
    "resourceList": {
      "type": "array",
      "items": { "$ref": "#/$defs/resource" }
    },
    "resource": {
      "type": "object",
      "required": ["kind", "name"],
      "properties": {
        "kind": { "type": "string" },
        "name": { "type": "string" },
        "path": { "type": "string" },
        "mode": { "type": "string" },
        "description": { "type": "string" },
        "schema": { "type": "string" },
        "source": { "type": "string" },
        "tool": { "type": "string" },
        "secret": { "type": ["string", "boolean"] },
        "handler": { "type": "string" },
        "executor": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "api-version": { "const": "tesseraft.fragment/v1" },
    "kind": { "const": "fragment" },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "version": { "type": "string" },
        "authors": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "interface": {
      "type": "object",
      "properties": {
        "inputs": { "type": "object" },
        "parameters": { "type": "object" },
        "outputs": { "type": "object" },
        "outcomes": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "minItems": 1
        }
      },
      "additionalProperties": true
    },
    "requirements": {
      "type": "object",
      "properties": {
        "executors": { "type": "array", "items": { "type": "string" } },
        "handlers": { "type": "array", "items": { "type": "string" } },
        "tools": { "type": "array", "items": { "type": "string" } },
        "secrets": { "type": "array", "items": { "type": "string" } },
        "template-vars": { "type": "array", "items": { "type": "string" } },
        "resources": { "$ref": "#/$defs/resourceDeclaration" }
      },
      "additionalProperties": true
    },
    "assets": {
      "type": "object",
      "properties": {
        "prompts": { "type": "array", "items": { "type": "string" } },
        "scripts": { "type": "array", "items": { "type": "string" } },
        "schemas": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "fragment": {
      "type": "object",
      "required": ["initial", "states"],
      "properties": {
        "initial": { "type": "string" },
        "defaults": { "type": "object" },
        "policies": { "type": "object" },
        "entry": {
          "type": "object",
          "properties": {
            "inputs": { "type": "array", "items": { "type": "string" } },
            "parameters": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        },
        "exit": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "on": { "type": "string" },
              "produces": { "type": "object" }
            },
            "additionalProperties": true
          }
        },
        "states": { "type": "object" },
        "resources": { "$ref": "#/$defs/resourceDeclaration" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}