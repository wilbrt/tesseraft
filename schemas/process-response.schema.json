{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tesseraft Process Node Response",
  "type": "object",
  "required": [
    "ok",
    "status"
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "description": "Declared workflow outcome for successful protocol responses. Nonzero process exits, malformed JSON, ok=false, or status=error are runtime/external failures."
    },
    "outputs": {
      "type": "object"
    },
    "summary": {
      "type": "string"
    },
    "error_type": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "log_file": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer"
    }
  },
  "additionalProperties": true
}
