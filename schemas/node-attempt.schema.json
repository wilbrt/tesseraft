{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tesseraft Node Attempt",
  "type": "object",
  "required": [
    "run_id",
    "node_id",
    "attempt",
    "status",
    "started_at"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "node_id": {
      "type": "string"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "description": "Attempt lifecycle status such as running, ok, error, failed, or blocked. Runtime/external failures should use error or failed."
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "executor": {
      "type": "string"
    },
    "handler": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_state": {
      "type": "string"
    },
    "result": {
      "type": "object",
      "description": "JSON-compatible node result or normalized runtime failure result."
    },
    "error": {
      "type": "string",
      "description": "Human-readable runtime/external failure summary when the attempt failed outside declared workflow semantics."
    },
    "log_file": {
      "type": "string"
    },
    "prompt_file": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
