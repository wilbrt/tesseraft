{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tesseraft Self-contained Node Package",
  "type": "object",
  "required": [
    "api-version",
    "kind",
    "metadata",
    "node"
  ],
  "properties": {
    "api-version": {
      "const": "tesseraft.node/v1"
    },
    "kind": {
      "const": "node"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "interface": {
      "type": "object",
      "properties": {
        "inputs": {
          "type": "object"
        },
        "outputs": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "requirements": {
      "type": "object",
      "properties": {
        "executors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "handlers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "template-vars": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "assets": {
      "type": "object",
      "properties": {
        "prompts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scripts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "schemas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "node": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "agent",
            "deterministic",
            "process",
            "timer",
            "approval",
            "router",
            "terminal"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
