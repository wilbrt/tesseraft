{:api-version "tesseraft.node/v1"
 :kind :node
 :metadata {:name "simple-design"
            :version "0.1.0"
            :description "Small valid self-contained node fixture."}
 :interface {:inputs {:prompt {:type :string :required true}}
             :outputs {:status {:schema "schemas/status.schema.json"}}}
 :requirements {:executors [:pi-cli]
                :tools [:read]
                :template-vars ["inputs.prompt" "run.dir"]
                :resources {:requires [{:kind :input :name "prompt" :mode :reusable}
                                       {:kind :capability :name "pi" :executor "pi-cli"}
                                       {:kind :tool :name "read" :tool "read"}]}}
 :assets {:prompts ["prompts/design.md.tmpl"]
          :schemas ["schemas/status.schema.json"]}
 :node {:type :agent
        :title "Design"
        :resources {:requires [{:kind :prompt :name "design-template" :path "prompts/design.md.tmpl"}]
                    :produces [{:kind :artifact :name "status" :path "design/status.json" :schema "schemas/status.schema.json"}
                               {:kind :design-doc :name "design" :path "design/design.md"}]}
        :executor :pi-cli
        :prompt-template "prompts/design.md.tmpl"
        :tools [:read]
        :runtime {:timeout "5m"}
        :outputs {:status {:path "design/status.json"
                           :schema "schemas/status.schema.json"
                           :required true}}}}
