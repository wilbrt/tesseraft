{:api-version "tesseraft.workflow/v1"
 :kind :workflow
 :metadata {:name "resource-undeclared-input"}
 :inputs {:prompt {:type :string :required true}}
 :defaults {:max-rounds 1 :state-timeout "1m"}
 :policies {:require-timeouts true :require-max-rounds true}
 :initial :consumer
 :states {:consumer {:type :deterministic
                     :handler :noop/succeed
                     :runtime {:timeout "1m"}
                     :resources {:requires [{:kind :input
                                             :name "promtp"
                                             :mode :read}]}
                     :next :done}
          :done {:type :terminal :status :success}}}
