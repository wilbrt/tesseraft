{:api-version "tesseraft.workflow/v1"
 :kind :workflow
 :metadata {:name "resource-ambient-path-mismatch"}
 :inputs {:prompt {:path "prompt/prompt.md" :required true}}
 :defaults {:config {:path "config/defaults.edn"}
            :max-rounds 1
            :state-timeout "1m"}
 :policies {:require-timeouts true :require-max-rounds true}
 :initial :consumer
 :states {:consumer {:type :deterministic
                     :handler :noop/succeed
                     :runtime {:timeout "1m"}
                     :resources {:requires [{:kind :input
                                             :name "prompt"
                                             :path "prompt/typo.md"
                                             :mode :read}
                                            {:kind :default
                                             :name "config"
                                             :path "config/typo.edn"
                                             :mode :read}]}
                     :next :done}
          :done {:type :terminal :status :success}}}
