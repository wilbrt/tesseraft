{:paths ["src"]
 :deps {cheshire/cheshire {:mvn/version "5.13.0"}}
 :tasks
 {lint {:doc "Standalone workflow linter"
        :requires ([tesseraft.lint.cli :as cli])
        :task (apply cli/-main *command-line-args*)}
  run {:doc "Reference workflow runner"
       :override-builtin true
       :requires ([tesseraft.runtime.cli :as cli])
       :task (apply cli/-main *command-line-args*)}
  node {:doc "Self-contained node package commands"
        :requires ([tesseraft.node.cli :as cli])
        :task (apply cli/-main *command-line-args*)}
  control-plane {:doc "Read-only local control-plane inspection commands"
                 :requires ([tesseraft.control-plane.cli :as cli])
                 :task (apply cli/-main *command-line-args*)}
  test {:doc "Run safe Tesseraft smoke checks"
        :task (shell "./scripts/test.sh")}
  status {:doc "Regenerate README status section from STATUS.edn (use --check for CI)"
          :task (apply shell "bb" "scripts/generate_status.clj" *command-line-args*)}}}
