.pi/
.tesseraft/*
!.tesseraft/project.json
.agent-runs/
node_modules/

# Resolved credential store (design §4.2) lives out-of-repo at
# ~/.tesseraft/credentials.json (or $TESSERAFT_HOME/credentials.json), which is
# outside the repo and therefore never tracked. Within the repo, the existing
# .tesseraft/ rule above already ignores any accidental .tesseraft/credentials.json.
# Project manifests under .tesseraft/projects/*.json store only credential
# references, never raw tokens; a linter guard rejects raw *_token values.

# Python cache files
__pycache__/
*.py[cod]

# Generated web build outputs
web/dist-server/
web/static/

# Generated Playwright diagnostics
playwright-report/
test-results/

# Container test scratch (build cache, logs). The harness under
# test/container/ itself is tracked; only its generated output is ignored.
test/container/logs/
test/container/build/
